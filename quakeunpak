#!/usr/bin/env python3
import struct, os, sys

def extract_pak(pak_path):
    if not os.path.exists(pak_path):
        print(f"Error: {pak_path} not found.")
        return
    with open(pak_path, 'rb') as f:
        header = f.read(12)
        magic, offset, length = struct.unpack('<4sII', header)
        if magic != b'PACK':
            print("Not a valid PAK file")
            return
        f.seek(offset)
        for _ in range(length // 64):
            entry = f.read(64)
            name, file_offset, file_len = struct.unpack('<56sII', entry)
            name = name.decode('ascii').strip('\x00').replace('\\', '/')
            dist_dir = os.path.dirname(name)
            if dist_dir:
                os.makedirs(dist_dir, exist_ok=True)
            pos = f.tell()
            f.seek(file_offset)
            data = f.read(file_len)
            with open(name, 'wb') as out:
                out.write(data)
            f.seek(pos)
            print(f"Extracted: {name}")

if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("Usage: python3 pak.py <filename.pak>")
    else:
        extract_pak(sys.argv[1])

